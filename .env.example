# -----------------------------------------------------------------------------
# BonBonK environment example
# -----------------------------------------------------------------------------
# Copy this file for local development:
#
#   cp .env.example .env.local
#
# Production .env.production is generated by GitHub Actions on the VPS.
# Do not commit real secrets.

# -----------------------------------------------------------------------------
# Docker image references
# -----------------------------------------------------------------------------
# Local development can use local image names.
# Production values are generated by the deploy workflow.
IMAGE_REPOSITORY=local/bonbonk
IMAGE_TAG=dev

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_VERSION=8.2
MONGO_INITDB_DATABASE=bonbonk
MONGO_INITDB_ROOT_USERNAME=bonbonk_root
MONGO_INITDB_ROOT_PASSWORD=change_me_mongo_root_password

# App connection values for later Laravel usage.
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DATABASE=bonbonk
MONGO_USERNAME=bonbonk_root
MONGO_PASSWORD=change_me_mongo_root_password
MONGO_AUTH_DATABASE=admin

# -----------------------------------------------------------------------------
# MariaDB
# -----------------------------------------------------------------------------
MARIADB_VERSION=11.8
MARIADB_ROOT_PASSWORD=change_me_mariadb_root_password
MARIADB_DATABASE=bonbonk
MARIADB_USER=bonbonk
MARIADB_PASSWORD=change_me_mariadb_app_password

# App connection values for later Laravel usage.
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=bonbonk
DB_USERNAME=bonbonk
DB_PASSWORD=change_me_mariadb_app_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_VERSION=8.6
REDIS_PASSWORD=change_me_redis_password

# App connection values for later Laravel usage.
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_VERSION=4.3.0

# App connection values for later Laravel / workers usage.
KAFKA_BROKERS=kafka:9092
KAFKA_GAME_TURNS_TOPIC=game.turns
